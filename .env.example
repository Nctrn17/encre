# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google AI Studio (Gemini API) : classification des opportunités
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter (fallback de cascade pour l'enrichissement quand Gemini est dégradé)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Voyage AI (embeddings)
VOYAGE_API_KEY=

# Resend (envoi des emails / digests)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Destinataire du digest de curation (interne)
CURATION_DIGEST_TO=

# Destinataire des previews de digest A/B (script de dev)
PREVIEW_DIGEST_TO=

# Cron auth (secret partagé entre les jobs planifiés et les API routes)
CRON_SECRET=

# Site URL (liens dans les emails + SEO)
# Dev : http://localhost:4000 / Prod : votre domaine
NEXT_PUBLIC_SITE_URL=http://localhost:4000

# Firecrawl (rendu JS pour les sources difficiles à parser en HTML statique)
# Free tier : 500 crédits/mois. Si absent, le fallback renvoie vide.
# https://firecrawl.dev
FIRECRAWL_API_KEY=
