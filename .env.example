# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google AI Studio (Gemini API) — classification des opportunités
# Modèles : gemma-4-31b-it (défaut, 1500 RPD free) + gemini-3-flash-preview (2e passe, 20 RPD free)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter (3e étage de cascade pour enrich:sections quand Gemini est dégradé)
# Modèle par défaut : deepseek/deepseek-chat-v3.1 (~$0.27/M input, function calling natif)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Voyage AI (embeddings)
VOYAGE_API_KEY=

# Resend (envoi email digests)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Cron auth (secret partagé GitHub Actions ↔ API routes)
CRON_SECRET=

# Site URL (utilisé pour les liens dans emails + SEO)
# Dev : http://localhost:4000 — Prod : https://encre.io
NEXT_PUBLIC_SITE_URL=http://localhost:4000

# Firecrawl (scraping JS-heavy + bypass Cloudflare)
# Free tier : 500 crédits/mois (1 crédit = 1 page scrapée).
# Utilisé pour Series Mania (heavy JS), ArtCena (Cloudflare), et autres
# sources que fetch standard n'arrive pas à parser.
# Si absent, les scrapers qui en dépendent log un warning et renvoient [].
# https://firecrawl.dev
FIRECRAWL_API_KEY=
