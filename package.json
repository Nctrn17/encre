{
  "name": "encre",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pipeline:process": "tsx scripts/trigger-pipeline.ts",
    "pilot:reclassify": "tsx scripts/reclassify-pilot-fields.ts",
    "resort:sections": "tsx scripts/resort-sections.ts",
    "backfill:deadline": "tsx scripts/backfill-deadline-from-calendar.ts",
    "eligibility:backfill": "tsx scripts/reclassify-pilot-fields.ts",
    "audit:eligibility": "tsx scripts/audit-eligibility.ts",
    "audit:matching": "tsx scripts/audit-matching.ts",
    "audit:urls": "tsx scripts/audit-source-urls.ts",
    "quality:calendar": "tsx scripts/auto-flag-calendar-patterns.ts",
    "eval:llm:extraction": "tsx scripts/eval-llm-extraction.ts",
    "eval:sources:extraction": "tsx scripts/eval-sources-extraction.ts",
    "reclassify:sections": "tsx scripts/reclassify-structured-fields.ts",
    "enrich:sections": "tsx scripts/enrich-from-page.ts",
    "cleanup:non-v1": "tsx scripts/cleanup-non-v1.ts",
    "digest:send": "tsx scripts/trigger-digest.ts",
    "digest:preview": "tsx scripts/trigger-digest.ts --preview --dump --ignore-last-sent",
    "db:migrate": "supabase db push",
    "db:types": "supabase gen types typescript --local > src/lib/supabase/types.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "feed": "^5.2.1",
    "ical-generator": "^10.2.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mendable/firecrawl-js": "^4.23.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^2.1.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "pdf-parse": "^2.4.5",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
